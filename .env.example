# MongoDB Connection
# For local development: mongodb://localhost:27017/healthcare_assistant
# For Docker: mongodb://mongo:27017/healthcare_assistant (set in docker-compose.yml)
MONGODB_URI=mongodb://localhost:27017/healthcare_assistant

# Mode: Set to 'true' for WhatsApp mode, leave empty or 'false' for CLI mode
USE_WHATSAPP='false'

# AI API Keys
# Get your API key from: https://platform.moonshot.cn/
KIMI_API_KEY=your_kimi_api_key_here

# Note: When running in Docker, MONGODB_URI is overridden in docker-compose.yml
# to point to the mongo service container.