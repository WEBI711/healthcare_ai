  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "docker:up": "docker compose up --watch",
    "docker:build": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "docker:clean": "docker compose down -v --rmi all --remove-orphans && docker system prune -f"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.1",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@agendajs/mongo-backend": "^4.0.1",
    "@mariozechner/pi-ai": "^0.67.68",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "agenda": "^6.2.4",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.5.0",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0"
  },
  "imports": {
    "#modules/*": "./dist/modules/*",
    "#models/*": "./dist/database/models/*",
    "#database/*": "./dist/database/*",
    "#routes/*": "./dist/routes/*",
    "#src/*": "./dist/*"
  }
}
